# Copy this file to `.env.local` (gitignored) for local development.
# Next.js reads `.env.local` automatically — no need to restart
# unless you ADD new variables. Changing an existing value hot-reloads.
#
# Any variable prefixed with NEXT_PUBLIC_ is inlined into the client
# bundle at BUILD TIME. Do NOT put secrets there.

# --- Lab routes ---
# Controls every route under `app/(lab)/*` — /lab, /lab-builder,
# /lab-methods, /lab-wip-5, etc. — plus the Lab entry points in the
# hero role row and the desktop nav pill.
#
# - "true"  -> lab is visible, routes render, nav/hero links shown
# - unset   -> lab routes return 404, nav/hero links tree-shaken
#
# On Vercel: set this variable in Project Settings → Environment
# Variables scoped to "Preview" and "Development" only. Leave it
# UNSET for "Production" so main-branch deploys ship without any
# lab surface.
NEXT_PUBLIC_ENABLE_LAB=true
